# Copy to .env for local netlify dev (do not commit .env).
# In production, set these in Netlify Site settings Environment variables.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Maps JavaScript API key (Place Autocomplete widget). In Google Cloud enable Maps JavaScript API
# and Places API (New); restrict the key by HTTP referrer.
GOOGLE_MAPS_API_KEY=
